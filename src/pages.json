{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "globalStyle": {
    "navigationBarTextStyle": "white", // 导航栏标题颜色及状态栏前景颜色，仅支持 black/white
    "navigationBarTitleText": "uniapp-template", // 导航栏标题文字内容
    "navigationBarBackgroundColor": "#2979ff" // 导航栏背景颜色（同状态栏背景色）
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationStyle": "custom" // 使用自定义导航栏
      }
    },
    {
      "path": "pages/user/user",
      "style": {
        "navigationBarTitleText": "我" // 导航栏标题文字内容
      }
    },
    {
      "path": "pages/search/search",
      "style": {
        "navigationBarTitleText": "搜索" // 导航栏标题文字内容
      }
    }
  ],
  "tabBar": {
    "color": "#364856", // tab 上的文字默认颜色
    "selectedColor": "#2979ff", // tab 上的文字选中时的颜色
    // 最少 2 个、最多 5 个 tab
    "list": [
      {
        "pagePath": "pages/index/index",
        "iconPath": "static/tabbar/home.png",
        "selectedIconPath": "static/tabbar/home-fill.png",
        "text": "首页"
      },
      {
        "pagePath": "pages/search/search",
        "iconPath": "static/tabbar/search.png",
        "selectedIconPath": "static/tabbar/search-fill.png",
        "text": "搜索"
      },
      {
        "pagePath": "pages/user/user",
        "iconPath": "static/tabbar/user.png",
        "selectedIconPath": "static/tabbar/user-fill.png",
        "text": "我"
      }
    ]
  }
}
